{
  "info": {
    "name": "UCVME API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5001" },
    { "key": "token", "value": "" },
    { "key": "user_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "  pm.collectionVariables.set('user_id', res.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@test.com\",\n  \"password\": \"pass123\",\n  \"userType\": \"student\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "  pm.collectionVariables.set('user_id', res.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@test.com\",\n  \"password\": \"pass123\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/profile/{{user_id}}"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/profile/{{user_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"Hi, I'm a student looking for casual work.\",\n  \"skills\": [\"JavaScript\", \"Node.js\", \"MongoDB\"],\n  \"education\": [\n    {\n      \"institution\": \"RMIT University\",\n      \"qualification\": \"Bachelor of IT\",\n      \"year\": 2025\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Upload Profile Pic",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/profile/{{user_id}}/pic",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": "",
                  "description": "Select an image file (jpg, png, webp)"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Video",
      "item": [
        {
          "name": "Upload Video",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/video/{{user_id}}",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "video",
                  "type": "file",
                  "src": "",
                  "description": "Select a video file (mp4, mov, webm)"
                }
              ]
            }
          }
        },
        {
          "name": "Get Video",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/video/{{user_id}}"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Get Reviews",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/reviews/{{user_id}}"
          }
        },
        {
          "name": "Submit Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/reviews/{{user_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Great candidate, highly recommend!\",\n  \"rating\": 5\n}"
            }
          }
        }
      ]
    }
  ]
}
